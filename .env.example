# --- CONFIGURACIÓN DE TELEGRAM ---
TELEGRAM_BOT_TOKEN=tu_token_aqui
ALLOWED_CHAT_IDS=[]
WEBHOOK_URL=https://tu-dominio.com/webhook
WEBHOOK_SECRET_TOKEN=un_string_aleatorio_y_seguro

# --- CONFIGURACIÓN DE IA (GEMINI) ---
GEMINI_BINARY_PATH=/usr/local/bin/gemini

# MÉTODOS DE AUTH: 'api_key', 'google_auth', 'vertex_ai'
GEMINI_AUTH_METHOD=api_key

# Requerido si AUTH_METHOD = 'api_key'
GEMINI_API_KEY=tu_api_key_aqui
GEMINI_WORKSPACE= # Directorio de trabajo (opcional)

# Requerido si AUTH_METHOD = 'vertex_ai'
VERTEX_PROJECT_ID=tu-proyecto-google-cloud
VERTEX_LOCATION=us-central1

# --- INFRAESTRUCTURA ---
CLOUDFLARE_TOKEN=tu_token_de_cloudflare_tunnel

CHAT_ID=chat_123456789